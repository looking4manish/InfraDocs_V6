# InfraDocs deployment config. Copy to `.env` and edit.

# --- How is the UI exposed to the internet? Pick ONE ---------------------
# A) Domain you own + public IP: set DOMAIN to it → Caddy auto-Let's-Encrypt.
#    (Point the DNS A-record at the server's PUBLIC IP; open 80/443.)
# B) Cloudflare Tunnel (works anywhere, incl. behind NAT): set CF_TUNNEL_TOKEN +
#    COMPOSE_PROFILES=cloudflare. Route the tunnel hostname to http://localhost:8081.
# C) Tailscale Funnel (public URL, no domain): set TS_AUTHKEY +
#    COMPOSE_PROFILES=tailscale (needs Funnel+HTTPS enabled on your tailnet).
# The web runs on host networking; Caddy listens on the port set here.
# ":8081" = plain HTTP on that port (clean for curl/Tailscale/Cloudflare, which
# terminate TLS themselves) — keep it equal to WEB_PORT below. A real domain
# instead makes Caddy auto-provision TLS on 80/443.
DOMAIN=:8081

# Activates an exposure sidecar: "cloudflare" or "tailscale" (empty = none).
COMPOSE_PROFILES=
CF_TUNNEL_TOKEN=
TS_AUTHKEY=

# Admin login. Seeded as ADMIN_USER / Changeme001 on first run, then the wizard
# forces a password change. Set ADMIN_PASSWORD to override the initial password.
ADMIN_USER=admin
ADMIN_PASSWORD=

# Identity of THIS server in the dashboard (any short id, e.g. oci / n150 / prod-1).
SERVER_ID=infradocs
SERVER_NAME=InfraDocs

# Where this host's project folders live (one app per subfolder).
PROJECTS_ROOT=/home/youruser/projects

# --- Ports (defaults avoid clashing with a native InfraDocs install) ---
# For a clean standalone deploy you can set WEB_PORT=80 / WEB_TLS_PORT=443.
WEB_PORT=8081
WEB_TLS_PORT=8443
API_PORT=8090
MONGO_PORT=27018
