# InfraDocs deployment config. Copy to `.env` and edit.

# Public hostname the UI is served at. A real domain → Caddy auto-provisions
# Let's Encrypt TLS. Use "localhost" for a local/parallel test (plain HTTP).
DOMAIN=localhost

# Admin login (HTTP Basic). REQUIRED — no default. Pick a strong password.
ADMIN_USER=admin
ADMIN_PASSWORD=

# Where this host's project folders live (one app per subfolder).
PROJECTS_ROOT=/home/youruser/projects

# --- Ports (defaults avoid clashing with a native InfraDocs install) ---
# For a clean standalone deploy you can set WEB_PORT=80 / WEB_TLS_PORT=443.
WEB_PORT=8081
WEB_TLS_PORT=8443
API_PORT=8090
MONGO_PORT=27018
