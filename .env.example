# Copy to `.env` and fill in real values. `.env` is gitignored.

# MongoDB replica-set connection URI (3-node RS: biwi primary, OCI + N150 secondaries)
INFRADOCS_MONGO_URI=mongodb://USER:PASSWORD@HOST1:27017,HOST2:27017,HOST3:27017/?replicaSet=rs0&authSource=admin

# API basic-auth password (falls back to dev_password in config.yml if unset)
INFRADOCS_API_PASSWORD=
